---
export interface Props {
  title?: string;
}

const { title = 'kindle-llm' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style is:global>
      :root {
        --font-serif: Georgia, 'Times New Roman', 'Book Antiqua', serif;
        --font-sans: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
        --black: #000;
        --white: #fff;
        --gray: #666;
        --gray-light: #eee;
        --radius: 2rem;
      }

      * { box-sizing: border-box; margin: 0; padding: 0; }

      html, body {
        height: 100%;
        overflow: hidden;
      }

      body {
        font-family: var(--font-serif);
        font-size: 18px;
        line-height: 1.6;
        color: var(--black);
        background: var(--white);
      }

      /* ---- App Shell ---- */
      .app {
        display: flex;
        flex-direction: column;
        height: 100vh;
      }

      /* ---- Header Bar ---- */
      .header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0.5rem 1rem;
        border-bottom: 2px solid var(--black);
        font-family: var(--font-sans);
        font-size: 14px;
      }

      .header h1 {
        font-size: 1rem;
        font-weight: 700;
        letter-spacing: -0.02em;
      }

      .header-actions {
        display: flex;
        gap: 0.5rem;
      }

      .header button {
        background: none;
        border: 1px solid var(--black);
        padding: 0.25rem 0.75rem;
        font-family: var(--font-sans);
        font-size: 12px;
        border-radius: 1rem;
        cursor: pointer;
      }

      .header button:active {
        background: var(--black);
        color: var(--white);
      }

      /* ---- Reader Panel ---- */
      .reader {
        flex: 1;
        display: flex;
        flex-direction: column;
        min-height: 0;
        transition: flex 0.15s;
      }

      .reader.collapsed {
        flex: 0;
        overflow: hidden;
        max-height: 0;
      }

      .reader-edit {
        flex: 1;
        display: flex;
        flex-direction: column;
        padding: 0.5rem;
      }

      .reader-edit textarea {
        flex: 1;
        border: 1px solid var(--gray-light);
        padding: 1rem;
        font-family: var(--font-serif);
        font-size: 17px;
        line-height: 1.8;
        resize: none;
        outline: none;
        color: var(--black);
        background: var(--white);
      }

      .reader-edit textarea::placeholder {
        color: var(--gray);
      }

      .reader-view {
        flex: 1;
        overflow-y: auto;
        padding: 1rem;
        display: none;
      }

      .reader-view.active {
        display: block;
      }

      .reader-edit.hidden {
        display: none;
      }

      .reader-text p {
        margin-bottom: 1rem;
        text-indent: 1.5rem;
        text-align: justify;
      }

      .reader-actions {
        display: flex;
        gap: 0.5rem;
        padding: 0.5rem 0;
      }

      .btn {
        display: inline-block;
        padding: 0.5rem 1.25rem;
        background: var(--black);
        color: var(--white);
        border: none;
        border-radius: var(--radius);
        font-family: var(--font-sans);
        font-size: 14px;
        cursor: pointer;
      }

      .btn:active { opacity: 0.8; }

      .btn-outline {
        background: var(--white);
        color: var(--black);
        border: 1px solid var(--black);
      }

      /* ---- Divider ---- */
      .divider {
        height: 2px;
        background: var(--black);
        position: relative;
      }

      .divider button {
        position: absolute;
        left: 50%;
        top: 50%;
        transform: translate(-50%, -50%);
        background: var(--white);
        border: 1px solid var(--black);
        padding: 0.15rem 0.75rem;
        font-family: var(--font-sans);
        font-size: 11px;
        border-radius: 1rem;
        cursor: pointer;
        white-space: nowrap;
      }

      .divider button:active {
        background: var(--black);
        color: var(--white);
      }

      /* ---- Chat Panel ---- */
      .chat {
        flex: 1;
        display: flex;
        flex-direction: column;
        min-height: 0;
      }

      .messages {
        flex: 1;
        overflow-y: auto;
        padding: 0.75rem 1rem;
      }

      .msg {
        margin-bottom: 0.75rem;
        padding: 0.4rem 0;
        word-wrap: break-word;
      }

      .msg-label {
        font-family: var(--font-sans);
        font-size: 12px;
        font-weight: 600;
        color: var(--gray);
        margin-bottom: 0.15rem;
      }

      .msg-user .msg-content {
        font-weight: 500;
      }

      .msg-assistant .msg-content {
        border-left: 3px solid var(--black);
        padding-left: 0.6rem;
      }

      /* ---- Chat Input ---- */
      .chat-bar {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem;
        border-top: 1px solid var(--gray-light);
      }

      .chat-bar input[type="text"] {
        flex: 1;
        border: 1px solid var(--gray-light);
        padding: 0.65rem 1rem;
        font-family: var(--font-sans);
        font-size: 16px;
        border-radius: var(--radius);
        outline: none;
        -webkit-appearance: none;
      }

      .chat-bar input[type="text"]:focus {
        border-color: var(--black);
      }

      .chat-bar button {
        padding: 0.65rem 1.25rem;
        background: var(--black);
        color: var(--white);
        border: none;
        border-radius: var(--radius);
        font-family: var(--font-sans);
        font-size: 15px;
        cursor: pointer;
        white-space: nowrap;
        min-width: 70px;
      }

      .chat-bar button:active { opacity: 0.8; }

      /* htmx states */
      .htmx-indicator { display: none; }
      .htmx-request .htmx-indicator { display: inline; }
      .htmx-request .btn-label { display: none; }

      #thinking {
        text-align: center;
        padding: 0.4rem;
        color: var(--gray);
        font-style: italic;
        font-family: var(--font-sans);
        font-size: 14px;
      }

      /* ---- Empty State ---- */
      .empty-state {
        text-align: center;
        color: var(--gray);
        padding: 2rem 1rem;
        font-style: italic;
      }
    </style>
    <script src="https://unpkg.com/htmx.org@1.9.12" integrity="sha384-0o0NrxS//lO6CcbCpEpjUus4SvpHnb1c1G0Y4NU3S9DcT4TFQkV1yOk7bzbBQt13" crossorigin="anonymous"></script>
  </head>
  <body>
    <div class="app">
      <slot />
    </div>

    <script is:inline>
      // ---- Reader Toggle ----
      function toggleReader() {
        const reader = document.getElementById('reader-panel');
        const btn = document.getElementById('toggle-btn');
        reader.classList.toggle('collapsed');
        btn.textContent = reader.classList.contains('collapsed') ? '▽ Reading' : '△ Reading';
      }

      // ---- Load text into reader ----
      function loadReader() {
        const textarea = document.getElementById('reader-content');
        const text = textarea.value.trim();
        if (!text) return;

        // Store in hidden input for form submissions
        document.getElementById('reader-context').value = text;

        // Render paragraphs
        const html = text.split(/\n\n+/).map(p => '<p>' + p.replace(/\n/g, '<br>') + '</p>').join('');
        document.getElementById('reader-text').innerHTML = html;

        // Switch to view mode
        textarea.parentElement.classList.add('hidden');
        document.getElementById('reader-view').classList.add('active');
      }

      // ---- Back to edit mode ----
      function editReader() {
        document.getElementById('reader-view').classList.remove('active');
        document.getElementById('reader-content').parentElement.classList.remove('hidden');
      }

      // ---- Update history after htmx swaps ----
      document.addEventListener('htmx:afterSwap', function(e) {
        if (e.detail.pathInfo.requestPath !== '/api/chat') return;

        // Rebuild history from DOM
        var msgs = document.querySelectorAll('#messages .msg');
        var history = [];
        msgs.forEach(function(el) {
          history.push({
            role: el.dataset.role,
            content: el.dataset.content
          });
        });
        document.getElementById('message-history').value = JSON.stringify(history);

        // Scroll to bottom
        var container = document.getElementById('messages');
        container.scrollTop = container.scrollHeight;

        // Remove empty state
        var empty = document.getElementById('empty-state');
        if (empty) empty.remove();
      });

      // ---- Clear chat ----
      function clearChat() {
        document.getElementById('messages').innerHTML = '<div id="empty-state" class="empty-state">Ask a question about your reading…</div>';
        document.getElementById('message-history').value = '[]';
      }
    </script>
  </body>
</html>
