<div class="reader" id="reader-panel">
  <div class="reader-edit">
    <textarea
      id="reader-content"
      name="reader-content"
      placeholder="Paste a passage from your book, article, or paper…"
      rows="8"
    ></textarea>
    <div class="reader-actions">
      <button class="btn" onclick="loadReader()">Load Text</button>
    </div>
  </div>
  <div class="reader-view" id="reader-view">
    <div class="reader-text" id="reader-text"></div>
    <div class="reader-actions">
      <button class="btn-outline btn" onclick="editReader()">Edit</button>
    </div>
  </div>
</div>
